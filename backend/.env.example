# Server
PORT=3000
NODE_ENV=development

# Paths (absolute or relative to backend/)
UPLOAD_DIR=uploads
OUTPUT_DIR=output

# Audiveris OMR — set AUDIVERIS_BIN to your Audiveris executable
# macOS example: /Applications/Audiveris.app/Contents/MacOS/Audiveris
# Linux example: /usr/bin/audiveris
AUDIVERIS_BIN=
AUDIVERIS_TIMEOUT_MS=120000

# Max upload size in bytes (default 25 MB)
MAX_FILE_SIZE=26214400

# CORS — comma-separated origins, or * for development
CORS_ORIGIN=*
